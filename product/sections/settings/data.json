{
  "_meta": {
    "models": {
      "settings": "The top-level container for everything visible on the Settings screen. Holds all four category groups so the UI can render any panel from a single payload.",
      "integrations": "Connection state for the three external services Cratekeeper depends on: Spotify, Tidal, and Anthropic. Each carries enough info to render either a 'connected' or 'not connected' card.",
      "anthropic": "Anthropic-specific configuration beyond the API key: which model is selected, whether prompt caching is on, and a lifetime token + USD usage counter.",
      "filesystemRoots": "The three on-disk locations the app reads from and writes to. Each row carries live health data (reachable, free space, last scanned) so the UI can render the per-row badge without an extra fetch.",
      "buckets": "The editable genre vocabulary used by the Classify step. Each entry has a stable id, display name, current ordering, and a usage counter (how many tracks across all events sit in that bucket).",
      "apiAccess": "The local-only bearer token clients use to authenticate against the Cratekeeper API. Carries created/last-used timestamps and a masked preview of the value."
    },
    "relationships": [
      "Each Settings payload contains exactly one of: Integrations, FilesystemRoots, Buckets, ApiAccess",
      "Integrations contains three Service entries (spotify, tidal, anthropic) plus an Anthropic config block",
      "Buckets are the same vocabulary referenced by every Track's currentBucket / suggestedBucket in Event Detail",
      "FilesystemRoots health values are produced by the same scan job that the Library section depends on"
    ]
  },
